# ───────────────────────────────────────────────────────────────────────────
# OPES Health Systems — PRODUCTION environment template.
# Copy to `.env` on the live server and fill every CHANGE_ME. NEVER commit the real .env.
# Values marked ★ are the production-critical ones that differ from dev.
# ───────────────────────────────────────────────────────────────────────────

APP_NAME="OPES Health Systems"
APP_ENV=production                         # ★ was: local
APP_KEY=                                   # ★ run once on the server: php artisan key:generate
APP_DEBUG=false                            # ★ MUST be false in prod (was: true) — never leak stack traces
APP_URL=https://opeshealthsystems.com      # ★ your real https domain (was: http://ohs.test)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging — quieter + structured in prod
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                          # ★ was: debug

# Database (prod MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                          # ★ prod DB host
DB_PORT=3306
DB_DATABASE=CHANGE_ME                      # ★ prod database name
DB_USERNAME=CHANGE_ME                      # ★
DB_PASSWORD=CHANGE_ME                      # ★ strong password

# Sessions / cookies — secure in prod
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true                       # ★ recommended
SESSION_PATH=/
SESSION_DOMAIN=.opeshealthsystems.com      # ★ was: null
SESSION_SECURE_COOKIE=true                 # ★ add this — HTTPS-only cookies

# Queue + cache (notifications are queued — a worker MUST run)
QUEUE_CONNECTION=database                  # or redis
CACHE_STORE=database                       # or redis
BROADCAST_CONNECTION=log

# Redis (only if you use it for cache/queue/session)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — REQUIRED for notifications, password reset, demo confirmations (was: log)
MAIL_MAILER=smtp                           # ★ smtp / ses / postmark — NOT log
MAIL_HOST=CHANGE_ME                        # ★
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME                    # ★
MAIL_PASSWORD=CHANGE_ME                    # ★
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="contact@opeshealthsystems.com"
MAIL_FROM_NAME="${APP_NAME}"

# Filesystem (set to s3 + the AWS_* block if storing uploads on S3)
FILESYSTEM_DISK=local

# AWS / S3 (only if FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=CHANGE_ME
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
