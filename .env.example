APP_NAME="OPES Health Systems"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://opeshealthsystems.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ─────────────────────────────────────────────────────────
# For local dev: DB_CONNECTION=sqlite (uses database/database.sqlite)
# For production: DB_CONNECTION=mysql
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ohs
DB_USERNAME=ohs_user
DB_PASSWORD=

# ── Session & Cache ──────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.opeshealthsystems.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ── Mail ─────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=mail.opeshealthsystems.com
MAIL_PORT=587
MAIL_USERNAME=contact@opeshealthsystems.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="contact@opeshealthsystems.com"
MAIL_FROM_NAME="OPES Health Systems"

# ── Admin notification email (receives new lead alerts) ──────────────
ADMIN_EMAIL=admin@opeshealthsystems.com

VITE_APP_NAME="${APP_NAME}"
